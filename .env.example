VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=https://organic-mart-be.onrender.com
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_ENABLE_SEPAY_MOCK=false
VITE_ENABLE_ADMIN_MOCKS=false
APP_URL=http://localhost:3000

# ─── NOTE ──────────────────────────────────────────────────────────────────
# Tất cả biến phải có prefix VITE_ để Vite embed vào JS bundle.
# Secrets (webhook key, DB password, JWT, Cloudinary, etc.) KHÔNG được
# đưa vào FE. Chúng thuộc về backend, cấu hình trong Render Environment Variables.
#
# Backend SePay config (Render Environment Variables):
#   SEPAY_ENABLED=true
#   SEPAY_WEBHOOK_API_KEY=<secret_từ_SePay_Dashboard>
#   SEPAY_BANK_ACCOUNT=00003981468
#   SEPAY_BANK_CODE=TPB

